CODE:
class Solution {
    public int coinChange(int[] coins, int amount) {
        int dp[][]=new int[coins.length+1][amount+1];
        int n=dp.length;
        int m=dp[0].length;
        for(int i=0;i<m;i++){
            dp[0][i]=99999;
        }
        for(int i=1;i<n;i++){
            dp[i][0]=0;
        }
        for(int i=1;i<n;i++){
            for(int j=1;j<m;j++){
                if(j<coins[i-1]){
                    dp[i][j]=dp[i-1][j];
                }else{
                    dp[i][j]=Math.min(dp[i-1][j],dp[i][j-coins[i-1]]+1);
                }
            }
        }
        int result=dp[n-1][m-1];
        if(result>=99999)return -1;
        return result;
    }
}
