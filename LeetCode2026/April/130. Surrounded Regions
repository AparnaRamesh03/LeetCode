BFS:
class Solution {
    public void solve(char[][] board) {
        int m = board.length, n = board[0].length;
        Queue<int[]> q = new LinkedList<>();

        // Step 1: Add boundary O's
        for (int i = 0; i < m; i++) {
            if (board[i][0] == 'O') {
                q.add(new int[]{i, 0});
                board[i][0] = 'E';
            }
            if (board[i][n - 1] == 'O') {
                q.add(new int[]{i, n - 1});
                board[i][n - 1] = 'E';
            }
        }

        for (int j = 0; j < n; j++) {
            if (board[0][j] == 'O') {
                q.add(new int[]{0, j});
                board[0][j] = 'E';
            }
            if (board[m - 1][j] == 'O') {
                q.add(new int[]{m - 1, j});
                board[m - 1][j] = 'E';
            }
        }

        // Step 2: BFS
        int[][] dirs = {{1,0},{-1,0},{0,1},{0,-1}};
        while (!q.isEmpty()) {
            int[] cur = q.poll();

            for (int[] d : dirs) {
                int r = cur[0] + d[0];
                int c = cur[1] + d[1];

                if (r >= 0 && r < m && c >= 0 && c < n && board[r][c] == 'O') {
                    board[r][c] = 'E';
                    q.add(new int[]{r, c});
                }
            }
        }

        // Step 3: Convert
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (board[i][j] == 'O') board[i][j] = 'X';
                else if (board[i][j] == 'E') board[i][j] = 'O';
            }
        }
    }
}
