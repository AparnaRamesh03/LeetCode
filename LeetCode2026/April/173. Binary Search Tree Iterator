SOLUTION:
------------------------------------------------------------------------------------------------------------------------------------------------
TIME  COMPLEXITY:O(H) where h is the heigh of the tree
SPACE COMPLEXITY:O(H) for balanced binary tree it will be O(log n)
------------------------------------------------------------------------------------------------------------------------------------------------
Initialize an empty stack
Push all left nodes from root into stack

next():
3) Pop top node
4) If popped node has right child → push all its left nodes
5) Return node value

hasNext():
6) Return whether stack is not empty
------------------------------------------------------------------------------------------------------------------------------------------------
CODE:
/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class BSTIterator {
    Stack<TreeNode>st;
    public BSTIterator(TreeNode root) {
        st=new Stack<>();
        dfs(root);
    }
    
    public int next() {
        TreeNode node=st.pop();
        dfs(node.right);
        return node.val;
    }
    
    public boolean hasNext() {
        return !st.isEmpty();
    }
    public void dfs(TreeNode root){
       while(root!=null){
        st.push(root);
        root=root.left;
       }
    }
}

