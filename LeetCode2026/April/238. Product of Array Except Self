https://leetcode.com/problems/product-of-array-except-self/description/


QUESTION:
Input: nums = [1,2,3,4]
Output: [24,12,8,6]
SOLUTION:
-----------------------------------------------------------------------------------------------------------------------
TIME  COMPLEXITY:O(n)
SPACE COMPLEXITY:O(n)
-----------------------------------------------------------------------------------------------------------------------
[1 2 3 4]

[1  1  2 6]
[24 12 4 1]
[24 12 8 6]
-----------------------------------------------------------------------------------------------------------------------
CODE:
class Solution {
    public int[] productExceptSelf(int[] nums) {
        int temp1=1;
        int temp2=1;
        int res[]=new int[nums.length];
        for(int i=0;i<nums.length;i++){
            res[i]=temp1*temp2;
            temp1=res[i];
            temp2=nums[i];
        }
        temp1=1;
        temp2=1;
        for(int i=nums.length-1;i>=0;i--){
            res[i]=res[i]*temp1*temp2;
            temp1=temp1*temp2;
            temp2=nums[i];
        }
        return res;
    }
}
