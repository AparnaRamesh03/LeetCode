https://leetcode.com/problems/string-to-integer-atoi/description/


QUESTION:
Input: s = "42"
Output: 42

Input: s = " -042"
Output: -42

Input: s = "1337c0d3"
Output: 1337

SOLUTION:
-------------------------------------------------------------------------------------------------------------------------------
TIME  COMPLEXITY:O(n)
SPACE COMPLEXITY:O(n)
-------------------------------------------------------------------------------------------------------------------------------
Step 1: Check if  initially there is empty space and iterate until there is no empty space
Step 2: if(sign is + then 1 else -1.
Step 3: Call a helper function with the string,ith value,num,sign
Step 5: In the helper function calculate the values num=num*10+(s.charAt(i)-'0')
Step 6: If there is a character in between then give the value right there. else until you pass through fully return.
-------------------------------------------------------------------------------------------------------------------------------
CODE:
class Solution {
    static final int INT_MIN_VAL = -2147483648;
    static final int INT_MAX_VAL = 2147483647;
    public int myAtoi(String s) {
        int i=0;
        while(i<s.length() && s.charAt(i)==' ')i++;
        int sign=1;
        if(i<s.length() && (s.charAt(i)=='+' || s.charAt(i)=='-')){
            sign=(s.charAt(i)== '-')?-1:1;
            i++;
        }
        return helper(s,i,0,sign);
    }
    static int helper(String s,int i,long num,int sign){
        if(i>=s.length() || !Character.isDigit(s.charAt(i)))return (int)(sign*num);
        num=num*10+(s.charAt(i)-'0');
        if(sign*num <=INT_MIN_VAL)return INT_MIN_VAL;
        if(sign*num >=INT_MAX_VAL)return INT_MAX_VAL;
        return helper(s,i+1,num,sign);
    }
}
