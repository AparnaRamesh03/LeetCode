QUESTION:
[5,4,8,11,null,13,4,7,2,null,null,5,1]

Output: [[5],[8,4],[11,13,4],[1,5,2,7]]

SOLUTION: [DEQUEUE SOLUTION ALSO THERE]
TIME COMPLEXITY: O(n)
SPACE COMPLEXITY: O(n)
-------------------------------------------------------------------------------------------------------------------------------
used a flag to differentiate between where i should reverse and where not to reverse.
But otherwise its the classic bfs solution with queue.
-------------------------------------------------------------------------------------------------------------------------------
/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    List<List<Integer>>ar=new ArrayList<>();
    public List<List<Integer>> zigzagLevelOrder(TreeNode root) {
        if(root==null)return ar;
        Queue<TreeNode>q=new LinkedList<>();
        q.add(root);
        boolean flag=true;
        while(!q.isEmpty()){
            int size=q.size();
            ArrayList<Integer>list=new ArrayList<>();
            
            for(int i=0;i<size;i++){
                TreeNode node=q.poll();
                list.add(node.val);
                if(node.left!=null){
                    q.add(node.left);
                }
                if(node.right!=null){
                    q.add(node.right);
                }
            }
            if(!flag)Collections.reverse(list);
            ar.add(list);
            flag=!flag;

        }
        return ar;
    }
}
