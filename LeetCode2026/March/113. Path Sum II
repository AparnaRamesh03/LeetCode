https://leetcode.com/problems/path-sum-ii/description/

Description:
Input: root = [5,4,8,11,null,13,4,7,2,null,null,5,1], targetSum = 22
Output: [[5,4,11,2],[5,8,4,5]]
Explanation: There are two paths whose sum equals targetSum:
5 + 4 + 11 + 2 = 22
5 + 8 + 4 + 5 = 22


SOLUTION:
DFS
TIME COMPLEXITY: O(N)
SPACE COMPLEXITY: O(H)

/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    ArrayList<List<Integer>>ar=new ArrayList<>();
    public List<List<Integer>> pathSum(TreeNode root, int targetSum) {
        traverse(root,targetSum,0,new ArrayList<>());
        return ar;
    }
    public void traverse(TreeNode root,int targetSum,int sum,ArrayList<Integer>path){
        if(root==null)return;
        path.add(root.val);
        sum+=root.val;
        if((root.left==null && root.right==null) && sum==targetSum){
            ar.add(new ArrayList<>(path));
        }
        traverse(root.left,targetSum,sum,path);
        traverse(root.right,targetSum,sum,path);
        path.remove(path.size()-1);
    }
}
