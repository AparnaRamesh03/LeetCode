BFS SOlution:
Same but just use Queue.
--------------------------------------------------------------------------------------------------------------------------------

import java.util.*;

class Solution {
    public int numIslands(char[][] grid) {
        int count = 0;

        for (int i = 0; i < grid.length; i++) {
            for (int j = 0; j < grid[0].length; j++) {

                if (grid[i][j] == '1') {
                    bfs(grid, i, j);
                    count++;
                }

            }
        }
        return count;
    }

    public void bfs(char[][] grid, int i, int j) {
        Queue<int[]> q = new LinkedList<>();
        q.offer(new int[]{i, j});

        grid[i][j] = '0'; // mark visited

        int[][] dirs = {{0,1},{0,-1},{1,0},{-1,0}};

        while (!q.isEmpty()) {
            int[] curr = q.poll();

            for (int[] dir : dirs) {
                int r = curr[0] + dir[0];
                int c = curr[1] + dir[1];

                if (r >= 0 && r < grid.length &&
                    c >= 0 && c < grid[0].length &&
                    grid[r][c] == '1') {

                    q.offer(new int[]{r, c});
                    grid[r][c] = '0'; // mark visited
                }
            }
        }
    }
}
