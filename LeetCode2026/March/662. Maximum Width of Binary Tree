https://leetcode.com/problems/maximum-width-of-binary-tree/description/


Question:
Input: root = [1,3,2,5,null,null,9,6,null,7]
Output: 7
Explanation: The maximum width exists in the fourth level with length 7 (6,null,null,null,null,null,7).
Input: root = [1,3,2,5]
Output: 2

SOLUTION:
--------------------------------------------------------------------------------------------------------------------------
REMEMBER: to find the index of a tree left=2i+1 right=2i+2 where i is the index of the root value.
Eg:
          1
        3  2
      5      9
    6       7
index of 1->0
i(3)->2(0)+1=1
i(2)->2(0)+2=2
i(5)->2(1)+1=3
i(9)->2(2)+2=6
i(6)->2(3)+1=7
i(7)->2(6)+2=14
wdth is first element - last element

TIME COMPLEXITY: O(n)
SPACE COMPLEXITY: O(h) h is the heigh of the tree


--------------------------------------------------------------------------------------------------------------------------
/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public int widthOfBinaryTree(TreeNode root) {
        Queue<TreeNode> q = new LinkedList<>();
        q.add(root);
        int i = 0;
        HashMap<TreeNode, Integer> map = new HashMap<>();
        map.put(root, 0);
        int width=0;
        TreeNode first=new TreeNode();
        TreeNode last=new TreeNode();
        while (!q.isEmpty()) {
            int size = q.size();
            
            for (int j = 0; j < size; j++) {
                TreeNode node = q.poll();
                if (j == 0)
                    first = node;
                if (j == size - 1)
                    last = node;
                i = map.get(node);
                if (node.left != null) {
                    q.add(node.left);
                    map.put(node.left, (2 * i) + 1);
                }
                if (node.right != null) {
                    q.add(node.right);
                    map.put(node.right, (2 * i) + 2);
                }
            }
            System.out.print(first.val);
            System.out.println(last.val);
            int max = Math.abs(map.get(first) - map.get(last));
            width=Math.max(max,width);
        }
        return width+1;
    }
}
