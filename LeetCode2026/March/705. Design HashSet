https://leetcode.com/problems/design-hashset/description/

Question:
Input
["MyHashSet", "add", "add", "contains", "contains", "add", "contains", "remove", "contains"]
[[], [1], [2], [1], [3], [2], [2], [2], [2]]
Output
[null, null, null, true, false, null, true, null, false]
Explanation
MyHashSet myHashSet = new MyHashSet();
myHashSet.add(1);      // set = [1]
myHashSet.add(2);      // set = [1, 2]
myHashSet.contains(1); // return True
myHashSet.contains(3); // return False, (not found)
myHashSet.add(2);      // set = [1, 2]
myHashSet.contains(2); // return True
myHashSet.remove(2);   // set = [1]
myHashSet.contains(2); // return False, (already removed)
------------------------------------------------------------------------------------------------------------------------------
SOLUTION:

class MyHashSet {
    int primbucket;
    int secbucket;
    boolean[][] storage;

    public MyHashSet() {
        this.primbucket=100000;
        this.secbucket=100000;
        this.storage=new boolean[primbucket][];
    }
    public int primHash(int key){
        return key%primbucket;
    }
    public int secHash(int key){
        return key/secbucket;
    }
    
    public void add(int key) {
        int primIdx=primHash(key);
        int secIdx=secHash(key);
        if(storage[primIdx]==null)storage[primIdx]=new boolean[secIdx+1];
        storage[primIdx][secIdx]=true;
    }
    
    public void remove(int key) {
        int primIdx=primHash(key);
        int secIdx=secHash(key);
        if(storage[primIdx]!=null)storage[primIdx][secIdx]=false;
    }
    
    public boolean contains(int key) {
        int primIdx=primHash(key);
        int secIdx=secHash(key);
        if(storage[primIdx]!=null)return storage[primIdx][secIdx];
        else return false;
    }
    
}

