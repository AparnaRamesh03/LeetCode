SPACE changes :O(n)
class Solution {
    public String customSortString(String order, String s) {
        
        int[] freq = new int[26];
        StringBuilder sb = new StringBuilder();
        
        // count characters in s
        for(char c : s.toCharArray()){
            freq[c - 'a']++;
            System.out.print(freq[c - 'a']);
        }
        
        // place characters based on order
        for(char c : order.toCharArray()){
            while(freq[c - 'a'] > 0){
                sb.append(c);
                freq[c - 'a']--;
            }
        }
        
        // add remaining characters
        for(int i = 0; i < 26; i++){
            while(freq[i] > 0){
                sb.append((char)(i + 'a'));
                freq[i]--;
            }
        }
        
        return sb.toString();
    }
}
