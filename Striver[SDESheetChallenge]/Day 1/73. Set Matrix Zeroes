class Solution {
    public void setZeroes(int[][] matrix) {
        int n=matrix.length;
        int m=matrix[0].length;
        HashMap<Integer,Integer>map=new HashMap<>();
        Queue<int[]>q=new LinkedList<>();
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                if(matrix[i][j]==0)q.add(new int[]{i,j});
            }
        }
        while(!q.isEmpty()){
            int curr[]=q.poll();
            zero(matrix,curr[0],curr[1]);

        }
    }
    public void zero(int[][] matrix,int k,int l){
        for(int i=0;i<matrix.length;i++){
            if(matrix[i][l]!=0)matrix[i][l]=0;
        }
        for(int i=0;i<matrix[0].length;i++){
            if(matrix[k][i]!=0)matrix[k][i]=0;
        }
    }
}
